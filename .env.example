# Active AI provider: groq | claude | gemini  (default: groq)
VITE_AI_PROVIDER=groq

# Groq — free tier, llama-3.3-70b-versatile
# Get a key at https://console.groq.com/keys
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# Claude — paid, Anthropic
VITE_CLAUDE_API_KEY=
VITE_CLAUDE_MODEL=claude-haiku-4-5-20251001

# Gemini — free tier, Google
# Get a key at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash

# Claude CLI (local dev only — uses authenticated claude CLI, no API key needed)
# Auto-selected in dev mode when no provider preference is stored
# Set VITE_AI_PROVIDER=claude-cli to force it (not for production)
